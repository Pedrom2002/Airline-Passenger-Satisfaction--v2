# Environment Variables Example
# Copy this file to .env and update with your values

# Model Configuration
MODEL_PATH=models/xgboost_final.pkl
SCALER_PATH=models/scaler.pkl
ENCODERS_PATH=models/label_encoders.pkl
MODEL_INFO_PATH=models/model_info.json
FILL_VALUES_PATH=models/fill_values.json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
LOG_LEVEL=INFO

# Streamlit Configuration
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Security (for production)
SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# Database (optional)
DATABASE_URL=sqlite:///monitoring/predictions.db

# Monitoring (optional)
MLFLOW_TRACKING_URI=sqlite:///monitoring/mlflow.db
ENABLE_MONITORING=true

# Cloud Storage (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=

# Docker
DOCKER_IMAGE_NAME=airline-satisfaction
DOCKER_CONTAINER_NAME=airline-satisfaction-app